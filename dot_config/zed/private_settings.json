// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "terminal": {
    "font_weight": 550.0
  },
  "agent_buffer_font_size": 14.0,
  "ui_font_weight": 550.0,
  "buffer_font_weight": 550.0,
  "agent_servers": {
    "pi-acp": {
      "type": "registry"
    },
    "claude-acp": {
      "type": "registry"
    },
    "codex-acp": {
      "type": "registry"
    },
    "opencode": {
      "type": "registry"
    }
  },
  "cli_default_open_behavior": "existing_window",
  "project_panel": {
    "dock": "left"
  },
  "outline_panel": {
    "dock": "left"
  },
  "collaboration_panel": {
    "dock": "left"
  },
  "git_panel": {
    "dock": "left"
  },
  "context_servers": {
    "mcp-server-context7": {
      "enabled": true,
      "remote": false,
      "settings": {
        "context7_api_key": ""
      }
    }
  },
  "icon_theme": "Colored Zed Icons Theme Dark",
  "agent": {
    "dock": "right",
    "default_profile": "ask",
    "default_model": {
      "enable_thinking": false,
      "provider": "opencode",
      "model": "mimo-v2-pro-free"
    },
    "favorite_models": [],
    "model_parameters": []
  },
  "ui_font_family": "Ubuntu Nerd Font",
  "buffer_font_family": "UbuntuMono Nerd Font Mono",
  "session": {
    "trust_all_worktrees": true
  },
  "vim_mode": true,
  "base_keymap": "VSCode",
  "ui_font_size": 16,
  "buffer_font_size": 15,
  "theme": {
    "mode": "system",
    "light": "DankShell Light",
    "dark": "DankShell Dark"
  },
}
