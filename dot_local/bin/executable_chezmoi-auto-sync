#!/usr/bin/env bash

set -euo pipefail

export PATH="/usr/local/bin:/usr/bin:/bin:$HOME/.local/bin:$PATH"

repo_dir="$HOME/.local/share/chezmoi"
branch="$(git -C "$repo_dir" symbolic-ref --quiet --short HEAD)"

chezmoi re-add --re-encrypt

if ! git -C "$repo_dir" diff --quiet --exit-code || ! git -C "$repo_dir" diff --cached --quiet --exit-code || [[ -n "$(git -C "$repo_dir" ls-files --others --exclude-standard)" ]]; then
  git -C "$repo_dir" add -A
  git -C "$repo_dir" commit -m "Update: sync dotfiles" -m "Refresh managed files from the current machine and store the latest changes captured by the daily chezmoi sync job."
fi

git -C "$repo_dir" pull --rebase origin "$branch"
git -C "$repo_dir" push origin "$branch"
