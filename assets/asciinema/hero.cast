[0.000, "o", "8;2;26;17;16m\u001b[59m\u001b[29m\u001b[28m\u001b[27m\u001b[25m\u001b[25m\u001b[22m\u001b[24m\u001b[22m\u001b[23m\u001b]8;;\u001b\\   10 \u001b[38;2;255;220;217m\u001b[48;2;34;23;22m> \u001b[38;2;255;249;248mThis repo is first a real daily-driver setup, not \u001b[19;2H\u001b[m\u001b[38;2;165;154;153m\u001b[48;2;26;17;16m\u001b[59m\u001b[29m\u001b[28m\u001b[27m\u001b[25m\u001b[25m\u001b[22m\u001b[24m\u001b[22m\u001b[23m\u001b]8;;\u001b\\      \u001b[38;2;255;249;248m\u001b[48;2;34;23;22ma generic starter. It is organized to be restorable,\u001b[20;2H\u001b[m\u001b[38;2;165;154;153m\u001b[48;2;26;17;16m\u001b[59m\u001b[29m\u001b[28m\u001b[27m\u001b[25m\u001b[25m\u001b[22m\u001b[24m\u001b[22m\u001b[23m\u001b]8;;\u001b\\      \u001b[38;2;255;249;248m\u001b[48;2;34;23;22m readable, and maintainable without dragging in brow\u001b[21;2H\u001b[m\u001b[38;2;165;154;153m\u001b[48;2;26;17;16m\u001b[59m\u001b[29m\u001b[28m\u001b[27m\u001b[25m\u001b[25m\u001b[22m\u001b[24m\u001b[22m\u001b[23m\u001b]8;;\u001b\\      \u001b[38;2;255;249;248m\u001b[48;2;34;23;22mser profiles, caches, or other machine junk.\u001b[39m\u001b[48;2;26;17;16m        \u001b[22;2H\u001b[m\u001b[38;2;165;154;153m\u001b[48;2;26;17;16m\u001b[59m\u001b[29m\u001b[28m\u001b[27m\u001b[25m\u001b[25m\u001b[22m\u001b[24m\u001b[22m\u001b[23m\u001b]8;;\u001b\\   11 \u001b[39m                                                    \u001b[23;2H\u001b[m\u001b[38;2;165;154;153m\u001b[48;2;26;17;16m\u001b[59m\u001b[29m\u001b[28m\u001b[27m\u001b[25m\u001b[25m\u001b[22m\u001b[24m\u001b[22m\u001b[23m\u001b]8;;\u001b\\   12 \u001b[38;2;255;190;184m## Preview\u001b[39m                                          \u001b[24;2H\u001b[m\u001b[38;2;165;154;153m\u001b[48;2;26;17;16m\u001b[59m\u001b[29m\u001b[28m\u001b[27m\u001b[25m\u001b[25m\u001b[22m\u001b[24m\u001b[22m\u001b[23m\u001b]8;;\u001b\\   13 \u001b[39m                                                    \u001b[25;2H\u001b[m\u001b[38;2;165;154;153m\u001b[48;2;26;17;